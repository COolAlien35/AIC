# .env.example — API keys template for AIC.
# Copy to .env and fill in your values, then `source .env` (or use direnv / your IDE).
# .env itself is gitignored so secrets never reach the repo.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED for the rubric-mandated OpenAI baseline
# (scripts/openai_baseline.py — judges run this with their own key)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: only set if you want to swap the heuristic specialists for
# Claude-backed LLM sub-agents (use_llm_agents=True). Disabled by default.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: only needed if you want to push the trained adapter to the
# Hugging Face Hub via eval/test_export.py --push.
# ─────────────────────────────────────────────────────────────────────────────
HF_TOKEN=hf_your-hugging-face-token-here

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: pin the OpenAI model used by the baseline script.
# Default is gpt-4o-mini — cheap and rubric-aligned. gpt-4o or gpt-4.1 also work.
# ─────────────────────────────────────────────────────────────────────────────
# AIC_OPENAI_MODEL=gpt-4o-mini
